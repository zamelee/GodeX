{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Model Probe",
  "identifier": "com.godex.model-probe",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {}
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "模型能力探测",
        "width": 900,
        "height": 750,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
